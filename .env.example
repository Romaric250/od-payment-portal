# Database
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/od-payment-portal?retryWrites=true&w=majority"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-secret"

# Fapshi (sandbox | live)
FAPSHI_ENV="sandbox"
FAPSHI_API_USER="your-fapshi-api-user"
FAPSHI_API_KEY="your-fapshi-api-key"
FAPSHI_WEBHOOK_SECRET=""

# Resend
RESEND_API_KEY="re_..."
EMAIL_FROM="Open Dreams <payments@open-dreams.org>"

# UploadThing
UPLOADTHING_TOKEN="sk_live_..."

# App (set APP_URL in production — read at runtime for payment redirects)
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin access — required ?authid= value to reach /admin (e.g. /admin/login?authid=your-secret)
ADMIN_ACCESS_SECRET="your-secret-auth-id"

# Seed (optional — used by npm run db:seed)
SEED_ADMIN_EMAIL="admin@open-dreams.org"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Super Admin"
